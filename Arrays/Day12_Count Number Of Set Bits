public class CountSetBits {
    public static void main(String[] args) {

        int num = 13; // Binary: 1101
        int count = 0;

        while (num > 0) {
            count += (num & 1); // check last bit
            num = num >> 1;     // right shift
        }

        System.out.println("Set bits: " + count);
    }
}
